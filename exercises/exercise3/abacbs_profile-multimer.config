// Pawsey Setonix nf-core configuration profile
params {
    config_profile_description = 'Pawsey Setonix HPC profile provided by nf-core/configs'
    config_profile_contact     = 'Sarah Beecroft (@SarahBeecroft), Georgie Samaha (@georgiesamaha), Thomas Litfin (@tlitfin)'
    config_profile_url         = 'https://support.pawsey.org.au/documentation/display/US/Setonix+User+Guide'
    alphafold2_params_path = '/scratch/references/alphafold_feb2024/databases/params/*'
}

// Enable use of Singularity to run containers
singularity {
    enabled     = true
    autoMounts  = true
    autoCleanUp = true
    envWhitelist = 'SINGULARITY_BINDPATH, SINGULARITYENV_LD_LIBRARY_PATH, SINGULARITYENV_LD_PRELOAD'
}

// Submit up to 1024 concurrent jobs
executor {
    queueSize = 2
}

// Define process resource limits
// See: https://support.pawsey.org.au/documentation/pages/viewpage.action?pageId=121479736#RunningJobsonSetonix-Overview


process {
    resourceLimits = [
        memory:  230.GB ,
        cpus: 64
    ]
    executor       = 'slurm'
    clusterOptions = "--account=${System.getenv('PAWSEY_PROJECT')}"
    module         = 'singularity/3.11.4-nompi'
    cache          = 'lenient'
    stageInMode    = 'symlink'
    queue = { task.memory <= 230.GB ? 'work' : 'highmem' }

    withName: 'RUN_ALPHAFOLD2' {
	container = '/scratch/references/abacbs2025/containers/alphafold2-single.sif'
        time = { 12.h }
    }
    withName: 'RUN_ALPHAFOLD2_MSA' {
        time = { 12.h }
        cpus = 8
        memory = 16.GB
    }
    withName: 'RUN_ALPHAFOLD2_PRED' {
	    container = '/scratch/references/abacbs2025/containers/alphafold2_pred-single.sif'
	    ext.args = '--num_multimer_predictions_per_model=1 --run_relax=false'
        time = { 12.h }
    }
    withLabel: 'process_gpu' {
        clusterOptions = "--account=${params.slurm_account}-gpu --nodes=1 --gres=gpu:1 --gpus-per-task=1 --gpu-bind=closest"
        env.ROCR_VISIBLE_DEVICES=0
        env.HIP_VISIBLE_DEVICES=0

        queue = 'gpu'
        singularity.runOptions = ""
        cpus = null
        memory = null
    }
    withName: 'GENERATE_REPORT|MULTIQC' {
        executor = 'local' // We can only run lightweight processes locally when the parent job is submitted to a compute node.
    }
}
